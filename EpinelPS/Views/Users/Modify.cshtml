<script>
// Official Overload Gear Stat Scaling Table
const overspecTable = {
    7000800: [4.77, 5.47, 6.18, 6.88, 7.59, 8.29, 9.00, 9.70, 10.40, 11.11, 11.81, 12.52, 13.22, 13.93, 14.63],
    7000700: [27.84, 31.95, 36.06, 40.17, 44.28, 48.39, 52.50, 56.60, 60.71, 64.82, 68.93, 73.04, 77.15, 81.26, 85.37],
    7000500: [9.54, 10.94, 12.34, 13.75, 15.15, 16.55, 17.95, 19.35, 20.75, 22.15, 23.56, 24.96, 26.36, 27.76, 29.16],
    7001000: [1.98, 2.28, 2.57, 2.86, 3.16, 3.45, 3.75, 4.04, 4.33, 4.63, 4.92, 5.21, 5.51, 5.80, 6.09],
    7000900: [4.77, 5.47, 6.18, 6.88, 7.59, 8.29, 9.00, 9.70, 10.40, 11.11, 11.81, 12.52, 13.22, 13.93, 14.63],
    7000600: [4.77, 5.47, 6.18, 6.88, 7.59, 8.29, 9.00, 9.70, 10.40, 11.11, 11.81, 12.52, 13.22, 13.93, 14.63],
    7001100: [2.30, 2.64, 2.98, 3.32, 3.66, 4.00, 4.35, 4.69, 5.03, 5.37, 5.70, 6.05, 6.39, 6.73, 7.07],
    7001200: [6.64, 7.62, 8.60, 9.58, 10.56, 11.54, 12.52, 13.50, 14.48, 15.46, 16.44, 17.42, 18.40, 19.38, 20.36],
    7001300: [4.77, 5.47, 6.18, 6.88, 7.59, 8.29, 9.00, 9.70, 10.40, 11.11, 11.81, 12.52, 13.22, 13.93, 14.63]
};

/**
 * Toggles visibility of the phase input and stat preview based on selection
 */
function togglePhaseInput(selectElement) {
    const container = selectElement.closest('.input-group');
    const phaseInput = container.querySelector('.phase-input');
    const statPreview = container.querySelector('.stat-preview');

    if (selectElement.value === "0") {
        // NONE state: Allow 0 to be submitted to clear the slot
        phaseInput.style.display = 'none';
        statPreview.style.display = 'none';
        phaseInput.value = 0;
        phaseInput.setAttribute('min', '0'); 
    } else {
        // ACTIVE state: Enforce min 1 for valid stats
        phaseInput.style.display = 'block';
        statPreview.style.display = 'flex'; // Use flex for centering logic
        
        if (parseInt(phaseInput.value) < 1) {
            phaseInput.value = 1;
        }
        phaseInput.setAttribute('min', '1');
    }
    refreshStatPreview(selectElement);
}

/**
 * Updates the text preview (e.g., "11.81%") based on the selected Stat and Phase
 */
function refreshStatPreview(element) {
    const container = element.closest('.input-group');
    const baseIdSelect = container.querySelector('select[name="baseIds"]');
    if (!baseIdSelect) return;

    const baseId = parseInt(baseIdSelect.value);
    const phaseInput = container.querySelector('.phase-input');
    const phase = parseInt(phaseInput.value);
    const preview = container.querySelector('.stat-preview');

    // Only show % if we have a valid stat and a phase within the table range (1-15)
    if (baseId > 0 && phase >= 1 && phase <= 15) {
        const value = overspecTable[baseId][phase - 1];
        preview.innerText = value.toFixed(2) + "%";
    } else {
        preview.innerText = "";
    }
}

/**
 * Maxes out all gear slots for a specific Nikke card (15 for all active slots)
 */
function maxNikkeStats(btn) {
    const container = btn.closest('.nikke-container');
    const selects = container.querySelectorAll('select[name="baseIds"]');
    
    selects.forEach(select => {
        if (select.value !== "0") {
            const group = select.closest('.input-group');
            const phaseInput = group.querySelector('.phase-input');
            phaseInput.value = 15;
            refreshStatPreview(phaseInput);
        }
    });

    // Visual Feedback Flash
    btn.classList.replace('btn-outline-warning', 'btn-warning');
    setTimeout(() => btn.classList.replace('btn-warning', 'btn-outline-warning'), 300);
}

/**
 * Global function to max out all phase inputs within a form
 */
function maxAllSlots(button) {
    const form = button.closest('form');
    const phaseInputs = form.querySelectorAll('.phase-input');
    phaseInputs.forEach(input => {
        input.value = 15;
        refreshStatPreview(input);
    });
}

/**
 * True Save All: Iterates through every Nikke form on the page 
 * and submits their data to the server.
 */
async function saveAllNikkes(btn) {
    const forms = document.querySelectorAll('.nikke-form'); 
    if (forms.length === 0) return;

    const originalText = btn.innerHTML;
    btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Saving...';
    btn.disabled = true;

    try {
        // We use a simple for...of loop to save them one-by-one
        // This prevents the "File in use" IOException
        for (const form of forms) {
            await fetch(form.action, {
                method: 'POST',
                body: new FormData(form)
            });
        }

        btn.classList.replace('btn-accent', 'btn-success');
        btn.innerHTML = '<i class="fas fa-check"></i> All Saved!';
        
        setTimeout(() => {
            window.location.reload(); 
        }, 800);
    } catch (err) {
        console.error("Save failed:", err);
        btn.innerHTML = 'Error!';
        btn.disabled = false;
    }
}

// Tab Persistence: Remembers the active tab after refresh
document.addEventListener('DOMContentLoaded', () => {
    // 1. Initial State: Setup visibility and calculate initial percentages on load
    document.querySelectorAll('select[name="baseIds"]').forEach(select => {
        togglePhaseInput(select);
    });

    // 2. Global Listener: Catch manual number changes in phase inputs
    document.body.addEventListener('input', (e) => {
        if (e.target.classList.contains('phase-input')) {
            refreshStatPreview(e.target);
        }
    });

    // 3. Tab Persistence: Remembers active tab 
    const lastActiveTab = localStorage.getItem('selectedNikkeTab');
    if (lastActiveTab) {
        const tabTrigger = document.querySelector(`[data-bs-target="${lastActiveTab}"]`);
        if (tabTrigger) {
            const tab = new bootstrap.Tab(tabTrigger);
            tab.show();
        }
    }
    document.querySelectorAll('button[data-bs-toggle="pill"]').forEach(link => {
        link.addEventListener('shown.bs.tab', (e) => {
            localStorage.setItem('selectedNikkeTab', e.target.getAttribute('data-bs-target'));
        });
    });
});

</script>